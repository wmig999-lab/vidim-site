{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "brief.vidim.site" }],
      "destination": "/brief/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/privacy",
      "has": [{ "type": "host", "value": "brief.vidim.site" }],
      "destination": "https://vidim.site/privacy",
      "permanent": false
    },
    {
      "source": "/brief",
      "has": [{ "type": "host", "value": "vidim.site" }],
      "destination": "https://brief.vidim.site/",
      "permanent": true
    },
    {
      "source": "/brief/:path*",
      "has": [{ "type": "host", "value": "vidim.site" }],
      "destination": "https://brief.vidim.site/",
      "permanent": true
    },
    {
      "source": "/brief",
      "has": [{ "type": "host", "value": "www.vidim.site" }],
      "destination": "https://brief.vidim.site/",
      "permanent": true
    },
    {
      "source": "/brief/:path*",
      "has": [{ "type": "host", "value": "www.vidim.site" }],
      "destination": "https://brief.vidim.site/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "brief.vidim.site" }],
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
